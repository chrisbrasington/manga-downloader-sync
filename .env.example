# Copy to .env and set your value. .env is gitignored.
#
# Address the KOReader Manga Library plugin should point at. Enter it on the device
# under Manga Library -> Server. Use your server's LAN IP (or hostname) and the
# manga-api's KOReader port (8684 by default; the same API also serves the browser on 8681).
MANGA_SERVER_URL=http://192.168.0.x:8684
